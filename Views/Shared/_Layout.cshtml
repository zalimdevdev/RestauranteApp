@using RestauranteApp.Models
@inject AppDbContext DbContext
@{
    var datosNegocio = DbContext.DatosNegocios.FirstOrDefault();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(datosNegocio?.Nombre ?? "RestauranteApp")</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RestauranteApp.styles.css" asp-append-version="true" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm custom-navbar  box-shadow mb-3" >
            <div class="container-fluid">    
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    @if (!string.IsNullOrEmpty(datosNegocio?.LogoUrl))
                    {
                        <img src="@datosNegocio.LogoUrl" alt="@(datosNegocio?.Nombre ?? "Logo")" class="me-2" style="height: 40px;" />
                    }
                    @(datosNegocio?.Nombre ?? "Restaurante")
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index" >Home</a>
                        </li>
                        <!-- Punto de entrada al POS -->

    <!-- OPERACIÓN -->
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-dark" data-bs-toggle="dropdown">
             Operación
        </a>
      
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" asp-controller="Mesas">Mesas</a></li>
          
            <li><a class="dropdown-item" asp-controller="Mesas" asp-action="GestionVentaMesa" asp-action="Index">Gestión de Mesas</a></li>
          
            <li><a class="dropdown-item" asp-controller="ItemsMenu" asp-action="Index">Menú</a></li>
            <li><a class="dropdown-item" asp-controller="ItemsMenu"  asp-action="Create"  >+ Nuevo Platillo</a></li>
         
            <li><a class="dropdown-item" asp-controller="CategoriaMenus">Categorías</a></li>
            <li><a class="dropdown-item" asp-controller="CategoriaMenus" asp-action="Create">+ Nueva Categoria</a></li>
        </ul>
    </li>

    <!-- VENTAS -->
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-dark" data-bs-toggle="dropdown">
             Ventas
        </a>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" asp-controller="Facturas">Facturas</a></li>
            <li><a class="dropdown-item" asp-controller="Clientes">Clientes</a></li>
             <li><a class="dropdown-item" asp-controller="Clientes" asp-action="Create" >+ Nuevo Cliente</a></li>
        </ul>
    </li>

    <!-- ADMINISTRACIÓN -->
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-dark" data-bs-toggle="dropdown">
             Administración
        </a>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" asp-controller="Empleados">Empleados</a></li>
            <li><a class="dropdown-item" asp-controller="Empleados" asp-action="Create">+ Nuevo Empleado</a></li>
            <li><a class="dropdown-item" asp-controller="Gastos">Gastos</a></li>
            <li><a class="dropdown-item" asp-controller="Gastos" asp-action="Create">+ Nuevo Gasto</a></li>
        </ul>
    </li>

    <!-- ANÁLISIS -->
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Estadisticas">
             Estadísticas
        </a>
    </li>

    <!-- SISTEMA -->
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-dark" data-bs-toggle="dropdown">
            ⚙️ Sistema
        </a>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" asp-controller="UserRol">Usuarios y Roles</a></li>
               <hr>
            <li><a class="dropdown-item" asp-controller="Backups">Backups</a></li>




        </ul>
    </li>

</div>

