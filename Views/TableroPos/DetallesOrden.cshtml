@model RestauranteApp.ViewModels.OrdenVM

@{
    ViewData["Title"] = "Detalles de Orden #" + Model.NumeroOrden;
}

<div class="container">
    <!-- Encabezado de la orden -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3><i class="fas fa-receipt"></i> Orden #@Model.NumeroOrden</h3>
        </div>
        <div class="col-md-6 text-end">
            <span class="badge bg-@GetEstadoColor(Model.Estado) fs-5">@Model.NombreEstado</span>
        </div>
    </div>

    <!-- Información de la orden -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Información de la Orden</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Fecha:</strong> @Model.FechaHora.ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <div class="col-md-4">
                            <strong>Items:</strong> @Model.CantidadItems
                        </div>
                        <div class="col-md-4">
                            <strong>Total:</strong> <span class="text-success fs-5">$@Model.Total.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Detalles de la orden -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-utensils"></i> Items de la Orden</h5>
                </div>
                <div class="card-body">
                    @if (Model.Detalles.Any())
                    {
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th class="text-center">Cantidad</th>
                                    <th class="text-end">Precio</th>
                                    <th class="text-end">Subtotal</th>
                                    <th>Notas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detalle in Model.Detalles)
                                {
                                    <tr>
                                        <td>@detalle.NombreItem</td>
                                        <td class="text-center">@detalle.Cantidad</td>
                                        <td class="text-end">$@detalle.PrecioUnitario.ToString("N2")</td>
                                        <td class="text-end">$@detalle.Subtotal.ToString("N2")</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(detalle.Notas))
                                            {
                                                <small class="text-muted">@detalle.Notas</small>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-light">
                                    <th colspan="3" class="text-end">Total:</th>
                                    <th class="text-end text-success">$@Model.Total.ToString("N2")</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> No hay items en esta orden.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Botones de acción -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-cogs"></i> Acciones</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Agregar items (solo si ABIERTA) -->
                        @if (Model.PuedeAgregarItems)
                        {
                            <div class="col-md-2 mb-2">
                                <a href="@Url.Action("AgregarItems", "TableroPos", new { ordenId = Model.OrdenId })" 
                                   class="btn btn-primary w-100">
                                    <i class="fas fa-plus"></i> Agregar Items
                                </a>
                            </div>
                        }

                        <!-- Enviar a cocina (si hay items) -->
                        @if (Model.PuedeEnviarACocina)
                        {
                            <div class="col-md-2 mb-2">
                                <form asp-action="EnviarAPreparacion" asp-controller="TableroPos" method="post" style="display:inline;">
                                    <input type="hidden" name="ordenId" value="@Model.OrdenId" />
                                    <button type="submit" class="btn btn-warning w-100">
                                        <i class="fas fa-fire"></i> Cocina
                                    </button>
                                </form>
                            </div>
                        }

                        <!-- Marcar como servida -->
                        @if (Model.PuedeMarcarServida)
                        {
                            <div class="col-md-2 mb-2">
                                <form asp-action="MarcarServida" asp-controller="TableroPos" method="post" style="display:inline;">
                                    <input type="hidden" name="ordenId" value="@Model.OrdenId" />
                                    <button type="submit" class="btn btn-info w-100">
                                        <i class="fas fa-check"></i> Servida
                                    </button>
                                </form>
                            </div>
                        }

                        <!-- Solicitar cuenta -->
                        @if (Model.PuedeSolicitarCuenta)
                        {
                            <div class="col-md-2 mb-2">
                                <form asp-action="SolicitarCuenta" asp-controller="TableroPos" method="post" style="display:inline;">
                                    <input type="hidden" name="ordenId" value="@Model.OrdenId" />
                                    <button type="submit" class="btn btn-secondary w-100">
                                        <i class="fas fa-file-invoice-dollar"></i> Cuenta
                                    </button>
                                </form>
                            </div>
                        }

                        <!-- Facturar -->
                        @if (Model.PuedeFacturar)
                        {
                            <div class="col-md-2 mb-2">
                                <a href="@Url.Action("Facturar", "TableroPos", new { ordenId = Model.OrdenId })" 
                                   class="btn btn-dark w-100">
                                    <i class="fas fa-receipt"></i> Facturar
                                </a>
                            </div>
                        }

                        <!-- Cerrar orden (después de pagar) -->
                        @if (Model.PuedeCerrar)
                        {
                            <div class="col-md-2 mb-2">
                                <form asp-action="ProcesarPago" asp-controller="TableroPos" method="post" style="display:inline;">
                                    <input type="hidden" name="ordenId" value="@Model.OrdenId" />
                                    <input type="hidden" name="metodoPago" value="EFECTIVO" />
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="fas fa-check-circle"></i> Cerrar
                                    </button>
                                </form>
                            </div>
                        }

                        <!-- Cancelar orden -->
                        @if (Model.PuedeCancelar)
                        {
                            <div class="col-md-2 mb-2">
                                <button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#modalCancelar">
                                    <i class="fas fa-times-circle"></i> Cancelar
                                </button>
                            </div>
                        }

                        <!-- Volver al tablero -->
                        <div class="col-md-2 mb-2">
                            <a href="@Url.Action("Index", "TableroPos")" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-arrow-left"></i> Volver
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para cancelar orden -->
@if (Model.PuedeCancelar)
{
    <div class="modal fade" id="modalCancelar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle"></i> Cancelar Orden</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="CancelarOrden" asp-controller="TableroPos" method="post">
                    <div class="modal-body">
                        <input type="hidden" name="ordenId" value="@Model.OrdenId" />
                        <div class="mb-3">
                            <label for="motivo" class="form-label">Motivo de cancelación:</label>
                            <textarea class="form-control" name="motivo" rows="3" required 
                                      placeholder="Ingrese el motivo de la cancelación..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                        <button type="submit" class="btn btn-danger">Confirmar Cancelación</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@functions {
    string GetEstadoColor(string estado)
    {
        return estado switch
        {
            "ABIERTA" => "primary",
            "EN_PREPARACION" => "warning",
            "SERVIDA" => "info",
            "SOLICITA_CUENTA" => "purple",
            "FACTURADA" => "secondary",
            "CERRADA" => "success",
            "CANCELADA" => "danger",
            _ => "secondary"
        };
    }
}